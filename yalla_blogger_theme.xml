<!DOCTYPE html>
<html b:css='false' b:defaultmessages='false' b:layoutsVersion='3' b:responsive='true' dir='ltr' lang='en' xmlns='http://www.w3.org/1999/xhtml' xmlns:b='http://www.google.com/2005/gml/b' xmlns:data='http://www.google.com/2005/gml/data' xmlns:expr='http://www.google.com/2005/gml/expr'>
<head>
  <meta charset='utf-8'/>
  <meta content='width=device-width, initial-scale=1' name='viewport'/>
  
  <b:if cond='data:blog.pageType == &quot;item&quot;'>
    <title><data:blog.pageName/> - <data:blog.title/></title>
  <b:else/>
    <title><data:blog.pageTitle/></title>
  </b:if>

  <!-- Google Fonts -->
  <link href='https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&amp;display=swap' rel='stylesheet'/>

  <b:skin><![CDATA[
    /*------------------------------------------------------------
    Theme Name: Minimal Responsive Core Shell
    Author: Antigravity AI
    ------------------------------------------------------------*/
    
    :root {
      --bg-color: #f4f6fa;
      --card-bg: #ffffff;
      --primary: #4d0b7a;
      --accent: #00b4d8;
      --text-main: #1a1e29;
      --text-gray: #5f667d;
      --border-color: rgba(0, 0, 0, 0.05);
      --rounded: 12px;
      --transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background-color: var(--bg-color);
      color: var(--text-main);
      font-family: 'Outfit', sans-serif;
      font-size: 15px;
      line-height: 1.6;
      padding: 0;
      margin: 0;
    }

    a {
      color: var(--primary);
      text-decoration: none;
      transition: var(--transition);
    }

    a:hover {
      color: var(--accent);
    }

    img, iframe {
      max-width: 100%;
      height: auto;
      border-radius: var(--rounded);
    }

    .container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 20px;
      width: 100%;
    }

    /* Minimal Header */
    #header-wrapper {
      background-color: #ffffff;
      border-bottom: 1px solid var(--border-color);
      box-shadow: 0 4px 20px rgba(0,0,0,0.02);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .header-inner {
      display: flex;
      justify-content: center; /* Center the logo beautifully since menu is removed */
      align-items: center;
      min-height: 70px;
      padding: 15px 0;
    }

    .logo-container a {
      font-size: 24px;
      font-weight: 900;
      letter-spacing: -0.5px;
      text-transform: uppercase;
      background: linear-gradient(135deg, var(--primary), var(--accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    /* Core Layout Shell Grid */
    .main-layout-grid {
      display: grid;
      grid-template-columns: 2.7fr 1fr;
      gap: 30px;
      margin: 30px 0;
    }

    .main-content-column {
      min-width: 0; /* Prevents flex/grid blowouts */
    }

    /* Minimal Footer */
    #footer-wrapper {
      background: #ffffff;
      border-top: 1px solid var(--border-color);
      padding: 25px 0;
      text-align: center;
      color: var(--text-gray);
      margin-top: 50px;
      font-size: 13px;
      font-weight: 600;
    }

    /* Responsive Queries */
    @media (max-width: 800px) {
      .header-inner {
        padding: 15px 0;
        text-align: center;
      }
      .main-layout-grid {
        grid-template-columns: 1fr;
        gap: 25px;
      }
    }
  ]]></b:skin>

