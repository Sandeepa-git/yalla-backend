<script type="text/javascript">
(function() {
  const FEED_CENTER_URL = 'https://yalla-backend-9por.onrender.com';

  async function fetchLiveScoresPro() {
    const grid = document.getElementById('yalla-widget-grid');
    const loader = document.getElementById('yalla-widget-loader');
    const matchCountBadge = document.getElementById('widget-match-count');
    if (!grid || !loader) return;

    try {
      const res = await fetch(`${FEED_CENTER_URL}/api/data`);
      const json = await res.json();
      
      if (json.success && json.data.matches && json.data.matches.length > 0) {
        let html = '';
        const matches = json.data.matches;
        
        // Update total match badge
        if (matchCountBadge) {
          matchCountBadge.textContent = `${matches.length} Matches`;
        }

        matches.forEach(m => {
          const isLive = m.statusClass === 'live';
          const isEnded = m.statusClass === 'finished';
          const statusClass = isLive ? 'live' : (isEnded ? 'ended' : 'not-started');
          
          let statusText = 'Not Started';
          let actionLabel = 'Watch Live Match ⚡';

          if (isLive) {
            statusText = 'LIVE';
            actionLabel = 'Watch Live Broadcast Now 📡';
          } else if (isEnded) {
            statusText = 'Ended';
            actionLabel = 'View Match Highlights ⚽';
          } else {
            if (m.statusText && m.statusText !== 'لم تبدأ بعد' && m.statusText !== 'not-started') {
              statusText = m.statusText;
            } else {
              statusText = 'Not Started';
            }
            actionLabel = 'View Channel & Lineups 📅';
          }

          // English fallbacks
          if (statusText === 'لم تبدأ بعد') statusText = 'Not Started';
          if (statusText === 'انتهت') statusText = 'Ended';

          // Format Score safely to show '0 - 0' instead of just '0'
          let displayScore = m.score || '0 - 0';
          if (displayScore.trim() === '0' || displayScore.trim() === '0-0') {
            displayScore = '0 - 0';
          }

          html += `
            <div class="match-card" onclick="window.open('${m.link}', '_blank')">
              <div class="match-inner">
                <div class="team home">
                  <img class="team-logo" src="${m.team1.logo || 'https://www.tv-yalla.live/wp-content/uploads/2026/05/cropped-لنثصلث-32x32.png'}" alt="${m.team1.name}"/>
                  <span class="team-name">${m.team1.name}</span>
                </div>
                <div class="match-center">
                  <span class="match-time">${m.time}</span>
                  <span class="match-score">${displayScore}</span>
                  <span class="match-status ${statusClass}">${statusText}</span>
                </div>
                <div class="team away">
                  <img class="team-logo" src="${m.team2.logo || 'https://www.tv-yalla.live/wp-content/uploads/2026/05/cropped-لنثصلث-32x32.png'}" alt="${m.team2.name}"/>
                  <span class="team-name">${m.team2.name}</span>
                </div>
              </div>
              <div class="match-meta">
                <span class="meta-item">📺 ${m.channel}</span>
                <span class="meta-item">🎤 ${m.commentator}</span>
                <span class="meta-item">🏆 ${m.tournament}</span>
              </div>
              <div class="card-action-overlay">
                ${actionLabel}
              </div>
            </div>
          `;
        });
        
        grid.innerHTML = html;
        loader.style.display = 'none';
        grid.style.display = 'grid';
      } else {
        showFallbackErrorPro("No live matches scheduled for today.");
      }
    } catch (err) {
      console.log("CORS/Fetch error: ", err);
      showFallbackErrorPro("Server Sync Failed. Please verify your Render instance is active.");
    }
  }

  function showFallbackErrorPro(message) {
    const loader = document.getElementById('yalla-widget-loader');
    if (loader) {
      loader.innerHTML = `
        <div style="font-size:28px;">⚽</div>
        <p style="color:#dc3545; font-weight:700; font-size:14px; letter-spacing:-0.2px;">${message}</p>
        <p style="font-size:11px; color:#5f667d; margin-top:-5px;">Pinging scraper backup feeds...</p>
      `;
    }
  }

  // Load fetch
  window.addEventListener('load', fetchLiveScoresPro);
})();
</script>]]></b:widget-setting>
